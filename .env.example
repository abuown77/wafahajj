# Wafa Hajj — environment variables
# Copy to .env.local (git-ignored) and fill in real values.

# ───────────────────────────────────────────────────
# Public (exposed to browser) — must be prefixed PUBLIC_
# ───────────────────────────────────────────────────

# Site canonical URL (used for canonical tags, sitemap, OG)
PUBLIC_SITE_URL=https://wafahajj.com

# WhatsApp business number — digits only, international format
PUBLIC_WHATSAPP_NUMBER=12342800554

# Google Analytics 4 measurement ID (G-XXXXXXXXXX). Blank disables GA4.
PUBLIC_GA4_ID=

# Facebook Pixel ID (optional — activate after first signed contract)
PUBLIC_FB_PIXEL_ID=
