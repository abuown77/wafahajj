---
/**
 * Wafa Hajj — Crescent Logo (adopted 4 June 2026)
 * Recreated as pure SVG to match the approved crescent mark.
 * No Kaaba, no dome. Gold crescent + seal ring on the brand palette.
 */
interface Props {
  scale?: number;          // visual scale multiplier
  stacked?: boolean;       // true = mark + wordmark stacked vertically
  onGreen?: boolean;       // adjusts colors for dark green backgrounds
  showWordmark?: boolean;  // show "Wafa Hajj" text beside/under the mark
  ariaLabel?: string;
}

const {
  scale = 1,
  stacked = false,
  onGreen = false,
  showWordmark = true,
  ariaLabel = 'Wafa Hajj',
} = Astro.props;

const markSize = 180 * scale;
const ringColor = onGreen ? 'rgba(228,197,130,0.55)' : 'rgba(200,155,60,0.5)';
---

<div
  class:list={['wh-logo', { 'wh-logo--stacked': stacked, 'wh-logo--on-green': onGreen }]}
  role="img"
  aria-label={ariaLabel}
  style={`--wh-logo-scale: ${scale};`}
>
  <svg
    class="wh-logo__mark"
    width={markSize}
    height={markSize}
    viewBox="0 0 180 180"
    aria-hidden="true"
  >
    <defs>
      <linearGradient id="wh-gold" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#E4C582" />
        <stop offset="55%" stop-color="#C89B3C" />
        <stop offset="100%" stop-color="#A87B28" />
      </linearGradient>
      <mask id="wh-crescent">
        <circle cx="90" cy="92" r="42" fill="#FFFFFF" />
        <circle cx="106" cy="80" r="37" fill="#000000" />
      </mask>
    </defs>

    {/* seal ring */}
    <circle cx="90" cy="90" r="72" fill="none" stroke={ringColor} stroke-width="1.4" />

    {/* gold crescent */}
    <circle cx="90" cy="92" r="42" fill="url(#wh-gold)" mask="url(#wh-crescent)" />
  </svg>

  {showWordmark && (
    <div class="wh-logo__wordmark">
      <span class="wh-logo__name">Wafa Hajj</span>
      <span class="wh-logo__nameAr">وفاء الحج</span>
    </div>
  )}
</div>

<style>
  .wh-logo {
    display: inline-flex;
    align-items: center;
    gap: calc(14px * var(--wh-logo-scale));
    line-height: 1;
  }
  .wh-logo--stacked {
    flex-direction: column;
    gap: calc(12px * var(--wh-logo-scale));
  }

  .wh-logo__mark { display: block; flex-shrink: 0; }

  .wh-logo__wordmark {
    display: flex;
    flex-direction: column;
    gap: calc(3px * var(--wh-logo-scale));
    line-height: 1;
  }
  .wh-logo--stacked .wh-logo__wordmark {
    align-items: center;
  }

  .wh-logo__name {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 500;
    font-size: calc(26px * var(--wh-logo-scale));
    letter-spacing: -0.01em;
    color: var(--c-secondary);
  }
  .wh-logo--on-green .wh-logo__name { color: #ffffff; }

  .wh-logo__nameAr {
    font-family: 'IBM Plex Sans Arabic', 'IBM Plex Sans', sans-serif;
    font-weight: 400;
    font-size: calc(11px * var(--wh-logo-scale));
    letter-spacing: 0.3em;
    color: var(--c-ink-soft);
    direction: rtl;
  }
  .wh-logo--on-green .wh-logo__nameAr { color: rgba(228, 197, 130, 0.7); }
</style>
