---
import { TELEGRAM } from '@config/site';

interface Props {
  variant?: 'telegram' | 'gold' | 'ghost';
  size?: 'default' | 'lg';
  class?: string;
}

const { variant = 'telegram', size = 'default', class: className } = Astro.props;
---

<a
  href={TELEGRAM.url}
  target="_blank"
  rel="noopener"
  class:list={['btn', `btn--${variant}`, size === 'lg' && 'btn--lg', className]}
  data-tg-link
>
  <svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22">
    <path d="M9.78 18.65l.28-4.23 7.68-6.92c.34-.31-.07-.46-.52-.19L7.74 13.3 3.64 12c-.88-.25-.89-.86.2-1.3l15.97-6.16c.73-.33 1.43.18 1.15 1.3l-2.72 12.81c-.19.91-.74 1.13-1.5.71L12.6 16.3l-1.99 1.93c-.23.23-.42.42-.83.42z"/>
  </svg>
  <span data-lang="en">Message us on Telegram</span>
  <span data-lang="ar">تواصل معنا عبر تلجرام</span>
  <span data-lang="sv">Kontakta oss på Telegram</span>
  <span data-lang="nb">Kontakt oss på Telegram</span>
</a>

<style>
  .btn--lg {
    padding: 1.15rem 2.5rem;
    font-size: 1.125rem;
  }
</style>
