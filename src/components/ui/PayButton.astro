---
interface Props {
  variant?: 'gold' | 'ghost';
  size?: 'default' | 'lg';
  class?: string;
}

const { variant = 'gold', size = 'lg', class: className } = Astro.props;
---

<a
  href="#register"
  class:list={['btn', `btn--${variant}`, size === 'lg' && 'btn--lg', className]}
  data-pay-link
>
  <svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22">
    <path d="M2 5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5zm2 0v3h16V5H4zm16 6H4v8h16v-8zM6 16h6v2H6v-2z"/>
  </svg>
  <span data-lang="en">Pay by card — $199</span>
  <span data-lang="ar">ادفع بالبطاقة — $199</span>
  <span data-lang="sv">Betala med kort — $199</span>
  <span data-lang="nb">Betal med kort — $199</span>
</a>

<style>
  .btn--lg {
    padding: 1.15rem 2.5rem;
    font-size: 1.125rem;
  }
</style>
