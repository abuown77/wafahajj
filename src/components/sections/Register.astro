---
/**
 * Register — on-site request form.
 * Collects: requester name + contact, deceased parent's name,
 * and a short voice recording pronouncing the name.
 * Delivery wiring (where submissions are sent) is handled separately.
 */
---

<section class="section section--cream register" id="register">
  <div class="container">
    <p class="eyebrow">
      <span data-lang="en">Start the request</span>
      <span data-lang="ar">ابدأ الطلب</span>
      <span data-lang="sv">Starta begäran</span>
      <span data-lang="nb">Start forespørselen</span>
    </p>
    <h2>
      <span data-lang="en">Request a proxy Umrah</span>
      <span data-lang="ar">اطلب عمرة بالنيابة</span>
      <span data-lang="sv">Begär en ställföreträdande Umrah</span>
      <span data-lang="nb">Be om en stedfortredende Umrah</span>
    </h2>
    <div class="ornament" aria-hidden="true"><span class="ornament-dot"></span></div>

    <p class="lead register__lead">
      <span data-lang="en">Tell us who the Umrah is for. Recording the name in your own voice helps us pronounce it correctly.</span>
      <span data-lang="ar">أخبرنا لمن تكون العمرة. تسجيل الاسم بصوتك يساعدنا على نطقه نطقاً صحيحاً.</span>
      <span data-lang="sv">Berätta vem Umrah är för. Att spela in namnet med din egen röst hjälper oss att uttala det rätt.</span>
      <span data-lang="nb">Fortell oss hvem Umrah er for. Å spille inn navnet med din egen stemme hjelper oss å uttale det riktig.</span>
    </p>

    <form class="register__form card" id="register-form" novalidate>
      <div class="field">
        <label for="rf-name">
          <span data-lang="en">Your name</span>
          <span data-lang="ar">اسمك</span>
          <span data-lang="sv">Ditt namn</span>
          <span data-lang="nb">Ditt navn</span>
        </label>
        <input type="text" id="rf-name" name="name" autocomplete="name" required />
      </div>

      <div class="field">
        <label for="rf-contact">
          <span data-lang="en">Your email or phone</span>
          <span data-lang="ar">بريدك الإلكتروني أو هاتفك</span>
          <span data-lang="sv">Din e-post eller telefon</span>
          <span data-lang="nb">Din e-post eller telefon</span>
        </label>
        <input type="text" id="rf-contact" name="contact" autocomplete="email" required />
      </div>

      <div class="field">
        <label for="rf-deceased">
          <span data-lang="en">Full name of the deceased</span>
          <span data-lang="ar">اسم المتوفّى كاملاً</span>
          <span data-lang="sv">Den avlidnes fullständiga namn</span>
          <span data-lang="nb">Avdødes fulle navn</span>
        </label>
        <input type="text" id="rf-deceased" name="deceased" required />
      </div>

      <div class="field">
        <span class="field__label">
          <span data-lang="en">Pronounce the name (voice)</span>
          <span data-lang="ar">انطق الاسم (تسجيل صوتي)</span>
          <span data-lang="sv">Uttala namnet (röst)</span>
          <span data-lang="nb">Uttal navnet (stemme)</span>
        </span>

        <div class="recorder" id="recorder">
          <button type="button" class="btn btn--ghost recorder__btn" id="rec-toggle">
            <span class="rec-dot" aria-hidden="true"></span>
            <span data-lang="en" class="rec-label" data-state="idle">Record</span>
            <span data-lang="ar" class="rec-label" data-state="idle">سجّل</span>
            <span data-lang="sv" class="rec-label" data-state="idle">Spela in</span>
            <span data-lang="nb" class="rec-label" data-state="idle">Spill inn</span>
          </button>
          <span class="recorder__timer" id="rec-timer" aria-live="polite"></span>
          <audio class="recorder__audio" id="rec-audio" controls hidden></audio>
        </div>
        <p class="recorder__hint" id="rec-hint"></p>
        <input type="hidden" name="voice" id="rf-voice" />
      </div>

      <button type="submit" class="btn btn--gold register__submit">
        <span data-lang="en">Send the request</span>
        <span data-lang="ar">أرسل الطلب</span>
        <span data-lang="sv">Skicka begäran</span>
        <span data-lang="nb">Send forespørselen</span>
      </button>

      <p class="register__privacy">
        <span data-lang="en">Your details are used only to fulfil this Umrah. Nothing is shared.</span>
        <span data-lang="ar">تُستخدم بياناتك لإتمام هذه العمرة فقط، ولا تُشارك مع أي جهة.</span>
        <span data-lang="sv">Dina uppgifter används endast för att utföra denna Umrah. Inget delas.</span>
        <span data-lang="nb">Opplysningene dine brukes kun til å utføre denne Umrah. Ingenting deles.</span>
      </p>
    </form>

    <div class="register__done card" id="register-done" hidden>
      <div class="register__check" aria-hidden="true">✓</div>
      <h3>
        <span data-lang="en">Request received</span>
        <span data-lang="ar">تم استلام طلبك</span>
        <span data-lang="sv">Begäran mottagen</span>
        <span data-lang="nb">Forespørsel mottatt</span>
      </h3>
      <p>
        <span data-lang="en">May Allah accept it. We will be in touch shortly.</span>
        <span data-lang="ar">تقبّل الله. سنتواصل معك قريباً.</span>
        <span data-lang="sv">Må Allah acceptera den. Vi hör av oss snart.</span>
        <span data-lang="nb">Måtte Allah akseptere den. Vi tar kontakt snart.</span>
      </p>
    </div>
  </div>
</section>

<style>
  .register__lead { margin-inline: auto; text-align: center; }

  .register__form {
    max-width: 560px;
    margin: var(--s-5) auto 0;
    display: grid;
    gap: var(--s-4);
    text-align: start;
  }

  .field { display: grid; gap: var(--s-2); }

  .field label,
  .field__label {
    font-weight: 600;
    font-size: var(--fs-sm);
    color: var(--c-secondary);
  }

  .field input {
    font-family: inherit;
    font-size: var(--fs-md);
    color: var(--c-ink);
    background: var(--c-paper);
    border: 1px solid var(--c-line);
    border-radius: var(--radius-md);
    padding: 0.85rem 1rem;
    width: 100%;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  html[lang="ar"] .field input { font-family: var(--ff-arabic); }
  .field input:focus {
    outline: none;
    border-color: var(--c-gold-500);
    box-shadow: 0 0 0 3px rgba(200, 155, 60, 0.18);
  }
  .field input[aria-invalid="true"] {
    border-color: var(--c-burgundy);
    box-shadow: 0 0 0 3px rgba(139, 45, 45, 0.14);
  }

  .recorder {
    display: flex;
    align-items: center;
    gap: var(--s-3);
    flex-wrap: wrap;
  }
  .recorder__btn { padding: 0.7rem 1.4rem; font-size: var(--fs-sm); }
  .rec-dot {
    width: 12px; height: 12px;
    border-radius: 50%;
    background: var(--c-burgundy);
    flex-shrink: 0;
  }
  .recorder.is-recording .rec-dot { animation: rec-pulse 1s var(--ease-soft) infinite; }
  @keyframes rec-pulse { 50% { opacity: 0.25; } }
  .recorder__timer {
    font-variant-numeric: tabular-nums;
    font-size: var(--fs-sm);
    color: var(--c-text-soft);
  }
  .recorder__audio { height: 40px; width: 100%; max-width: 340px; }
  .recorder__hint {
    font-size: var(--fs-xs);
    color: var(--c-text-soft);
    margin: var(--s-2) 0 0;
    min-height: 1em;
  }

  .register__submit { justify-content: center; margin-top: var(--s-2); }

  .register__privacy {
    font-size: var(--fs-xs);
    color: var(--c-text-soft);
    text-align: center;
    margin: 0;
  }

  .register__done {
    max-width: 560px;
    margin: var(--s-5) auto 0;
    text-align: center;
  }
  .register__check {
    width: 56px; height: 56px;
    margin: 0 auto var(--s-3);
    display: grid; place-items: center;
    border-radius: 50%;
    background: var(--c-gold-500);
    color: var(--c-green-900);
    font-size: 1.6rem;
    font-weight: 700;
  }
</style>

<script>
  const form = document.getElementById('register-form') as HTMLFormElement | null;
  if (form) {
    const toggle = document.getElementById('rec-toggle') as HTMLButtonElement;
    const recorderEl = document.getElementById('recorder') as HTMLElement;
    const timerEl = document.getElementById('rec-timer') as HTMLElement;
    const audioEl = document.getElementById('rec-audio') as HTMLAudioElement;
    const hintEl = document.getElementById('rec-hint') as HTMLElement;
    const voiceInput = document.getElementById('rf-voice') as HTMLInputElement;
    const doneEl = document.getElementById('register-done') as HTMLElement;

    const HINTS: Record<string, { unsupported: string; ready: string }> = {
      en: { unsupported: 'Voice recording is not supported on this browser — you can still send without it.', ready: 'Recording saved. You can play it back or record again.' },
      ar: { unsupported: 'التسجيل الصوتي غير مدعوم في هذا المتصفّح — يمكنك الإرسال بدونه.', ready: 'تم حفظ التسجيل. يمكنك سماعه أو إعادة التسجيل.' },
      sv: { unsupported: 'Röstinspelning stöds inte i denna webbläsare — du kan ändå skicka utan den.', ready: 'Inspelning sparad. Du kan spela upp eller spela in igen.' },
      nb: { unsupported: 'Stemmeopptak støttes ikke i denne nettleseren — du kan likevel sende uten.', ready: 'Opptak lagret. Du kan spille av eller spille inn på nytt.' },
    };
    const lang = () => document.documentElement.lang || 'en';
    const setRecLabel = (s: string) => {
      document.querySelectorAll<HTMLElement>('.rec-label').forEach((el) => { el.dataset.state = s; });
    };

    let mediaRecorder: MediaRecorder | null = null;
    let chunks: BlobPart[] = [];
    let timer = 0;
    let tick: number | undefined;

    const supported = typeof navigator !== 'undefined'
      && !!navigator.mediaDevices?.getUserMedia
      && typeof MediaRecorder !== 'undefined';

    if (!supported) {
      toggle.disabled = true;
      hintEl.textContent = (HINTS[lang()] || HINTS.en).unsupported;
    }

    const labelFor: Record<string, { rec: string; stop: string }> = {
      en: { rec: 'Record', stop: 'Stop' },
      ar: { rec: 'سجّل', stop: 'إيقاف' },
      sv: { rec: 'Spela in', stop: 'Stoppa' },
      nb: { rec: 'Spill inn', stop: 'Stopp' },
    };
    const applyLabel = (kind: 'rec' | 'stop') => {
      (['en', 'ar', 'sv', 'nb'] as const).forEach((l) => {
        const el = document.querySelector<HTMLElement>(`.rec-label[data-lang="${l}"]`);
        if (el) el.textContent = labelFor[l][kind];
      });
    };

    const fmt = (s: number) => `${String(Math.floor(s / 60)).padStart(2, '0')}:${String(s % 60).padStart(2, '0')}`;

    async function start() {
      try {
        const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
        chunks = [];
        mediaRecorder = new MediaRecorder(stream);
        mediaRecorder.ondataavailable = (e) => { if (e.data.size) chunks.push(e.data); };
        mediaRecorder.onstop = () => {
          stream.getTracks().forEach((t) => t.stop());
          const blob = new Blob(chunks, { type: mediaRecorder?.mimeType || 'audio/webm' });
          audioEl.src = URL.createObjectURL(blob);
          audioEl.hidden = false;
          const reader = new FileReader();
          reader.onload = () => { voiceInput.value = String(reader.result); };
          reader.readAsDataURL(blob);
          hintEl.textContent = (HINTS[lang()] || HINTS.en).ready;
        };
        mediaRecorder.start();
        recorderEl.classList.add('is-recording');
        applyLabel('stop');
        timer = 0; timerEl.textContent = fmt(0);
        tick = window.setInterval(() => { timer += 1; timerEl.textContent = fmt(timer); }, 1000);
      } catch {
        hintEl.textContent = (HINTS[lang()] || HINTS.en).unsupported;
      }
    }
    function stop() {
      if (mediaRecorder && mediaRecorder.state !== 'inactive') mediaRecorder.stop();
      recorderEl.classList.remove('is-recording');
      applyLabel('rec');
      if (tick) window.clearInterval(tick);
    }

    toggle.addEventListener('click', () => {
      if (recorderEl.classList.contains('is-recording')) stop();
      else start();
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      let ok = true;
      ['rf-name', 'rf-contact', 'rf-deceased'].forEach((id) => {
        const input = document.getElementById(id) as HTMLInputElement;
        const invalid = !input.value.trim();
        input.setAttribute('aria-invalid', invalid ? 'true' : 'false');
        if (invalid && ok) { input.focus(); ok = false; }
      });
      if (!ok) return;
      if (recorderEl.classList.contains('is-recording')) stop();
      // Delivery is wired in the next step; for now confirm capture.
      form.hidden = true;
      doneEl.hidden = false;
      doneEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }
</script>
