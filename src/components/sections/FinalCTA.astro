---
import PayButton from '@components/ui/PayButton.astro';
import { TELEGRAM, WHATSAPP } from '@config/site';
import { content as c } from '@lib/content';
---

<section class="section section--dark final-cta">
  <div class="container">
    <h2 class="display">
      {(['en','ar','sv','nb'] as const).map((l) => (
        <span data-lang={l}>{c.finalCta.headline[l]}</span>
      ))}
    </h2>
    <p class="lead">
      {(['en','ar','sv','nb'] as const).map((l) => (
        <span data-lang={l}>{c.finalCta.subhead[l]}</span>
      ))}
    </p>

    <div class="final-cta__action">
      <PayButton variant="gold" size="lg" />
    </div>

    <p class="final-cta__contact">
      <span data-lang="en">Have a question first? Reach us on <a href={TELEGRAM.url} target="_blank" rel="noopener">Telegram</a> or <a href={WHATSAPP.url} target="_blank" rel="noopener">WhatsApp</a>.</span>
      <span data-lang="ar">عندك سؤال أولاً؟ تواصل معنا عبر <a href={TELEGRAM.url} target="_blank" rel="noopener">تلجرام</a> أو <a href={WHATSAPP.url} target="_blank" rel="noopener">واتساب</a>.</span>
      <span data-lang="sv">Har du en fråga först? Nå oss på <a href={TELEGRAM.url} target="_blank" rel="noopener">Telegram</a> eller <a href={WHATSAPP.url} target="_blank" rel="noopener">WhatsApp</a>.</span>
      <span data-lang="nb">Har du et spørsmål først? Ta kontakt på <a href={TELEGRAM.url} target="_blank" rel="noopener">Telegram</a> eller <a href={WHATSAPP.url} target="_blank" rel="noopener">WhatsApp</a>.</span>
    </p>
  </div>
</section>

<style>
  .final-cta {
    text-align: center;
  }
  .final-cta h2 {
    color: var(--c-gold-300);
    font-size: clamp(2rem, 3.5vw + 1rem, var(--fs-3xl));
    max-width: 22ch;
    margin-inline: auto;
  }
  .final-cta .lead {
    max-width: 42ch;
    margin: 0 auto var(--s-5);
    color: rgba(245, 241, 232, 0.82);
  }
  .final-cta__action {
    margin: var(--s-4) 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-3);
    justify-content: center;
    align-items: center;
  }
  .final-cta__contact {
    margin-top: var(--s-4);
    font-size: var(--fs-sm);
    color: rgba(245, 241, 232, 0.55);
  }
  .final-cta__contact a {
    color: var(--c-gold-300);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .final-cta__contact a:hover { color: #fff; }
</style>
