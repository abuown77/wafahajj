---
import Logo from '@components/Logo.astro';
import { content as c } from '@lib/content';
---

<section class="hero section--dark">
  <div class="hero__ornament-frame" aria-hidden="true">
    <span></span><span></span>
  </div>

  <div class="container hero__inner">
    <div class="hero__logo">
      <Logo scale={0.9} stacked onGreen showWordmark={false} />
    </div>

    <div class="ornament" aria-hidden="true"><span class="ornament-dot"></span></div>

    <p class="hero__eyebrow">
      {(['en','ar','sv','nb'] as const).map((l) => (
        <span data-lang={l}>{c.hero.eyebrow[l]}</span>
      ))}
    </p>

    <h1 class="hero__title display">
      {(['en','ar','sv','nb'] as const).map((l) => (
        <span data-lang={l}>
          {c.hero.headline[l].split('\n').map((line, i) => (
            <Fragment>{i > 0 && <br />}{line}</Fragment>
          ))}
          <br />
          <em>{c.hero.headlineAccent[l]}</em>
        </span>
      ))}
    </h1>

    <p class="hero__subhead lead">
      {(['en','ar','sv','nb'] as const).map((l) => (
        <span data-lang={l}>{c.hero.subhead[l]}</span>
      ))}
    </p>

    <div class="hero__actions">
      <a class="btn btn--gold btn--lg" href="#register">
        {(['en','ar','sv','nb'] as const).map((l) => (
          <span data-lang={l}>{c.hero.primaryCta[l]}</span>
        ))}
      </a>
      <a class="btn btn--ghost" href="#pricing">
        {(['en','ar','sv','nb'] as const).map((l) => (
          <span data-lang={l}>{c.hero.secondaryCta[l]}</span>
        ))}
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(var(--s-6), 10vw, var(--s-8));
    text-align: center;
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero__logo { margin-bottom: var(--s-3); }

  .hero__eyebrow {
    font-family: var(--ff-body);
    font-size: clamp(1.1rem, 1.4vw + 0.7rem, 1.75rem);
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--c-gold-300);
    margin: 0 0 var(--s-3);
    opacity: 1;
    display: inline-block;
    transform-origin: center;
    animation: wh-brand-pop 6s ease-in-out infinite;
  }
  /* Arabic is cursive — never track it, and use the Arabic face */
  :global(html[lang="ar"]) .hero__eyebrow {
    letter-spacing: normal;
    font-family: var(--ff-arabic);
  }
  /* the brand name catches the eye: rises + nearly vanishes, then pops back larger */
  @keyframes wh-brand-pop {
    0%, 62% { transform: translateY(0) scale(1); opacity: 1; }
    69% { transform: translateY(-5px) scale(1.03); opacity: 0.12; }
    77% { transform: translateY(0) scale(1.16); opacity: 1; }
    88%, 100% { transform: translateY(0) scale(1); opacity: 1; }
  }

  .hero__title {
    margin: 0 auto var(--s-4);
    color: #fff;
    max-width: 18ch;
    font-size: clamp(2rem, 4.5vw + 1rem, 4.25rem);
  }
  .hero__title em {
    color: var(--c-gold-300);
    font-style: italic;
    display: inline-block;
    margin-top: 0.1em;
  }
  :global(html[lang="ar"]) .hero__title em { font-style: normal; }

  .hero__subhead {
    max-width: 52ch;
    margin: 0 auto var(--s-5);
    text-align: center;
    color: rgba(245, 241, 232, 0.82);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-3);
    justify-content: center;
    align-items: center;
  }
  .hero__actions .btn--lg {
    padding: 1.15rem 2.5rem;
    font-size: 1.125rem;
  }

  /* gold frame decoration (inset borders from handoff) */
  .hero__ornament-frame {
    position: absolute;
    inset: 14px;
    pointer-events: none;
    z-index: 1;
  }
  .hero__ornament-frame span {
    position: absolute;
    inset: 0;
    border: 1px solid var(--c-gold-300);
    opacity: 0.22;
  }
  .hero__ornament-frame span:last-child {
    inset: 8px;
    border-width: 0.5px;
    opacity: 0.14;
  }
</style>
