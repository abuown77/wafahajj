---
import { content as c } from '@lib/content';
---

<section class="section section--cream">
  <div class="container">
    <p class="eyebrow">
      {(['en','ar','sv','nb'] as const).map((l) => (
        <span data-lang={l}>{c.problem.eyebrow[l]}</span>
      ))}
    </p>
    <h2>
      {(['en','ar','sv','nb'] as const).map((l) => (
        <span data-lang={l}>{c.problem.headline[l]}</span>
      ))}
    </h2>

    <div class="ornament" aria-hidden="true"><span class="ornament-dot"></span></div>

    <ul class="problem-list">
      {[0, 1, 2].map((idx) => (
        <li class="problem-item">
          {(['en','ar','sv','nb'] as const).map((l) => (
            <span data-lang={l}>{c.problem.questions[l][idx]}</span>
          ))}
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .problem-list {
    list-style: none;
    padding: 0;
    margin: var(--s-5) auto 0;
    display: grid;
    gap: var(--s-3);
    max-width: 720px;
  }
  .problem-item {
    background: #fff;
    padding: var(--s-4) var(--s-5);
    border-inline-start: 3px solid var(--c-gold-500);
    border-radius: 4px;
    font-family: var(--ff-display);
    font-style: italic;
    font-size: var(--fs-lg);
    color: var(--c-secondary);
    box-shadow: var(--shadow-card);
  }
  :global(html[lang="ar"]) .problem-item {
    font-family: var(--ff-arabic);
    font-style: normal;
    font-weight: 500;
  }
</style>
