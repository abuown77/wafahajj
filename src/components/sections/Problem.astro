---
import { content as c } from '@lib/content';
---

<section class="section section--cream problem">
  <div class="container problem__inner">
    <div class="ornament" aria-hidden="true"><span class="ornament-dot"></span></div>

    <ul class="problem-list">
      {c.problem.questions.en.map((_, idx) => (
        <li class="problem-item">
          {(['en','ar','sv','nb'] as const).map((l) => (
            <span data-lang={l}>{c.problem.questions[l][idx]}</span>
          ))}
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .problem { text-align: center; }
  .problem__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-4);
  }
  .problem-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    max-width: 32ch;
  }
  .problem-item {
    font-family: var(--ff-display);
    font-style: italic;
    font-size: clamp(1.5rem, 3vw + 0.5rem, 2.5rem);
    line-height: 1.25;
    color: var(--c-secondary);
    letter-spacing: -0.01em;
  }
  :global(html[lang="ar"]) .problem-item {
    font-family: var(--ff-arabic);
    font-style: normal;
    font-weight: 500;
    font-size: clamp(1.4rem, 3vw + 0.4rem, 2.25rem);
    /* Arabic is cursive — any tracking breaks the letter joins. Keep it normal. */
    letter-spacing: normal;
    line-height: 1.6;
  }
  :global(html[lang="ar"]) .problem-list {
    max-width: none;
    text-wrap: balance;
  }
</style>
