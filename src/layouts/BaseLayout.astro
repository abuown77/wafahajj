---
import '@styles/design-system.css';
import Meta from '@components/seo/Meta.astro';
import ServiceSchema from '@components/seo/ServiceSchema.astro';

interface Props {
  bodyClass?: string;
}
const { bodyClass = '' } = Astro.props;

const GA4_ID = import.meta.env.PUBLIC_GA4_ID;

// Normalise base so it always ends with a single "/"
const BASE = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${BASE}favicon.svg`} />
    <link rel="apple-touch-icon" href={`${BASE}apple-touch-icon.png`} />

    <!-- Fonts: 3 families only (Playfair Display + IBM Plex Sans + IBM Plex Sans Arabic) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;1,400;1,500;1,600&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Sans+Arabic:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <Meta />
    <ServiceSchema />

    {GA4_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
        <script is:inline define:vars={{ GA4_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', GA4_ID, { send_page_view: true });
          window.gtag = gtag;
        </script>
      </>
    )}

    <!-- i18n bootstrap — runs before paint to prevent flash of wrong language -->
    <script is:inline>
      (function () {
        var LOCALES = ['en', 'ar', 'sv', 'nb'];
        var UTM_MAP = { usa: 'en', canada: 'en', sweden: 'sv', norway: 'nb' };
        var DEFAULT = 'en';
        var RTL = ['ar'];

        function isLocale(v) { return LOCALES.indexOf(v) !== -1; }

        var locale = DEFAULT;
        try {
          var stored = localStorage.getItem('wh-lang');
          if (isLocale(stored)) locale = stored;
          else {
            var params = new URLSearchParams(location.search);
            var utm = (params.get('utm_campaign') || '').toLowerCase();
            if (utm && UTM_MAP[utm]) locale = UTM_MAP[utm];
          }
        } catch (e) { /* ignore */ }

        document.documentElement.setAttribute('lang', locale);
        document.documentElement.setAttribute('dir', RTL.indexOf(locale) !== -1 ? 'rtl' : 'ltr');
      })();
    </script>
  </head>
  <body class={bodyClass}>
    <slot />

    <!-- i18n interactive layer -->
    <script>
      import { resolveInitialLocale, applyLocale, bindTabs } from '../lib/i18n.ts';

      const initial = resolveInitialLocale();
      applyLocale(initial);
      bindTabs();

      // Track WhatsApp clicks
      document.querySelectorAll('[data-wa-link]').forEach((a) => {
        a.addEventListener('click', () => {
          // @ts-ignore
          if (typeof window.gtag === 'function') {
            // @ts-ignore
            window.gtag('event', 'whatsapp_click', {
              event_category: 'cta',
              event_label: document.documentElement.lang,
            });
          }
        });
      });
    </script>
  </body>
</html>
