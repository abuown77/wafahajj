---
import '@styles/design-system.css';
import Meta from '@components/seo/Meta.astro';
import ServiceSchema from '@components/seo/ServiceSchema.astro';
import FaqSchema from '@components/seo/FaqSchema.astro';

interface Props {
  bodyClass?: string;
}
const { bodyClass = '' } = Astro.props;

// Normalise base so it always ends with a single "/"
const BASE = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${BASE}favicon.svg`} />
    <link rel="apple-touch-icon" href={`${BASE}apple-touch-icon.png`} />

    <!-- Fonts: 3 families only (Playfair Display + IBM Plex Sans + IBM Plex Sans Arabic) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;1,400;1,500;1,600&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Sans+Arabic:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <Meta />
    <ServiceSchema />
    <FaqSchema />

    <!-- Google tag — GA4 analytics (G-) + Google Ads conversion (AW-). Purchase fires on Fourthwall. -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-NRL1KT7J8D"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-NRL1KT7J8D', { send_page_view: true });
      gtag('config', 'AW-18255385299');
      window.gtag = gtag;
    </script>

    <!-- Meta (Facebook) Pixel -->
    <script is:inline>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '2225454741623409');
      fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none" alt="" src="https://www.facebook.com/tr?id=2225454741623409&ev=PageView&noscript=1" /></noscript>

    <!-- i18n bootstrap — runs before paint to prevent flash of wrong language -->
    <script is:inline>
      (function () {
        var LOCALES = ['en', 'ar', 'sv', 'nb'];
        var UTM_MAP = { usa: 'en', canada: 'en', sweden: 'sv', norway: 'nb' };
        var DEFAULT = 'en';
        var RTL = ['ar'];

        function isLocale(v) { return LOCALES.indexOf(v) !== -1; }

        var locale = DEFAULT;
        try {
          var stored = localStorage.getItem('wh-lang');
          if (isLocale(stored)) locale = stored;
          else {
            var params = new URLSearchParams(location.search);
            var utm = (params.get('utm_campaign') || '').toLowerCase();
            if (utm && UTM_MAP[utm]) locale = UTM_MAP[utm];
          }
        } catch (e) { /* ignore */ }

        document.documentElement.setAttribute('lang', locale);
        document.documentElement.setAttribute('dir', RTL.indexOf(locale) !== -1 ? 'rtl' : 'ltr');
        // Mark JS available so scroll-reveal styles apply (set before paint = no flash)
        document.documentElement.classList.add('js');
      })();
    </script>
  </head>
  <body class={bodyClass}>
    <slot />

    <!-- i18n interactive layer -->
    <script>
      import { resolveInitialLocale, applyLocale, bindTabs } from '../lib/i18n.ts';

      const initial = resolveInitialLocale();
      applyLocale(initial);
      bindTabs();

      // Track Telegram clicks
      document.querySelectorAll('[data-tg-link]').forEach((a) => {
        a.addEventListener('click', () => {
          // @ts-ignore
          if (typeof window.gtag === 'function') {
            // @ts-ignore
            window.gtag('event', 'telegram_click', {
              event_category: 'cta',
              event_label: document.documentElement.lang,
            });
          }
          // @ts-ignore
          if (typeof window.fbq === 'function') window.fbq('track', 'Lead');
        });
      });

      // Track card-payment clicks
      document.querySelectorAll('[data-pay-link]').forEach((a) => {
        a.addEventListener('click', () => {
          // @ts-ignore
          if (typeof window.gtag === 'function') {
            // @ts-ignore
            window.gtag('event', 'pay_click', {
              event_category: 'cta',
              event_label: document.documentElement.lang,
            });
          }
          // @ts-ignore
          if (typeof window.fbq === 'function') {
            // @ts-ignore
            window.fbq('track', 'InitiateCheckout', { value: 199, currency: 'USD' });
          }
        });
      });

      // Funnel counter — reveals exactly where visitors drop off between landing and payment.
      // Steps: page_view → view_form → form_start → request_submitted → (Purchase on checkout).
      function whTrack(name) {
        var lang = document.documentElement.lang;
        // @ts-ignore
        if (typeof window.gtag === 'function') window.gtag('event', name, { event_category: 'funnel', event_label: lang });
        // @ts-ignore
        if (typeof window.fbq === 'function') window.fbq('trackCustom', name, { lang: lang });
      }
      // @ts-ignore
      window.whTrack = whTrack;

      // Step: visitor reached the order form (scrolled it into view)
      var regSection = document.getElementById('register');
      if (regSection && 'IntersectionObserver' in window) {
        var seenForm = false;
        var formObserver = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting && !seenForm) {
              seenForm = true;
              whTrack('view_form');
              formObserver.disconnect();
            }
          });
        }, { threshold: 0.3 });
        formObserver.observe(regSection);
      }

      // Step: visitor started filling the form (first field interaction)
      var regForm = document.getElementById('register-form');
      if (regForm) {
        var formStarted = false;
        regForm.addEventListener('input', function () {
          if (!formStarted) { formStarted = true; whTrack('form_start'); }
        });
      }

    </script>

    <!-- Scroll-reveal: content rises into view as you scroll (the eye follows motion).
         Isolated + fully guarded: any failure reveals everything so content is never hidden. -->
    <script>
      (function () {
        var revealSelector =
          '.section h2,.eyebrow,.ornament,.feature,.step,.pricing-row,.pledge,.proof-list li,.problem-item,.faq-item';
        var reveals = Array.prototype.slice.call(document.querySelectorAll(revealSelector));
        function revealAll() {
          reveals.forEach(function (el) {
            el.classList.add('is-visible');
          });
        }
        try {
          // Stagger siblings that share a parent so groups cascade in
          var groups = new Map();
          reveals.forEach(function (el) {
            var parent = el.parentElement;
            if (!parent) return;
            var arr = groups.get(parent) || [];
            arr.push(el);
            groups.set(parent, arr);
          });
          groups.forEach(function (arr) {
            arr.forEach(function (el, i) {
              el.style.transitionDelay = Math.min(i, 6) * 80 + 'ms';
            });
          });

          if ('IntersectionObserver' in window) {
            var io = new IntersectionObserver(
              function (entries) {
                entries.forEach(function (entry) {
                  if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    io.unobserve(entry.target);
                  }
                });
              },
              { rootMargin: '0px 0px -8% 0px', threshold: 0.04 },
            );
            reveals.forEach(function (el) {
              io.observe(el);
            });
          } else {
            revealAll();
          }
        } catch (e) {
          revealAll();
        }
      })();
    </script>
  </body>
</html>
